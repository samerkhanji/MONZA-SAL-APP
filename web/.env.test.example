# Copy to `.env.test` locally (NEVER commit the filled-in copy).

# Leave blank to auto-boot `next dev` on http://127.0.0.1:3000.
# Set to https://monzacrm.vercel.app to run against production
# (use sparingly — tests create/delete DB rows).
PLAYWRIGHT_BASE_URL=

# Account Playwright uses to sign in. Its profile row is force-reset to
# must_change_password=false + is_active=true in global-setup.
TEST_EMAIL=owner@example.com
TEST_PASSWORD=

# Service-role credentials for DB verification + cleanup. NEVER commit.
# Dashboard → Project Settings → API → service_role (secret). Starts with eyJ…
SUPABASE_SERVICE_ROLE_KEY=

# Optional — only set if different from NEXT_PUBLIC_SUPABASE_URL in .env.local.
# PLAYWRIGHT_SUPABASE_URL=

{
  "id": "/",
  "name": "Monza App",
  "short_name": "Monza",
  "description": "Monza S.A.L. - Vehicle & Business Management",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#111827",
  "theme_color": "#F59E0B",
  "orientation": "any",
  "categories": ["business", "productivity"],
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "Add Customer",
      "short_name": "New customer",
      "description": "Create a new customer record",
      "url": "/customers/add",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    },
    {
      "name": "New Sales Order",
      "short_name": "Sales orders",
      "description": "Open the sales orders list to create a new order",
      "url": "/sales-orders",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    },
    {
      "name": "Garage Tasks",
      "short_name": "Tasks",
      "description": "Garage task board",
      "url": "/garage/tasks",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  },
  "screenshots": [
    {
      "src": "/images/screenshots/mobile-dashboard.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard on mobile"
    },
    {
      "src": "/images/screenshots/desktop-dashboard.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard on desktop"
    }
  ]
}

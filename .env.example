# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://okxpsvukzjjubinhamek.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Optional alternative name (same key from Supabase API settings):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Auth redirect base (no trailing slash). Production: set to your live origin so password-reset
# and magic-link redirectTo values match Supabase → Authentication → URL Configuration.
# Omit on Vercel preview so each deployment uses its own origin (add https://*.vercel.app/** to Redirect URLs).
# NEXT_PUBLIC_SITE_URL=https://monzacrm.vercel.app
#
# Supabase Site URL: https://monzacrm.vercel.app (example)
# Redirect URLs should include at least:
#   https://monzacrm.vercel.app
#   https://monzacrm.vercel.app/auth/callback
#   https://monzacrm.vercel.app/reset-password
#   http://localhost:3000/**
#   https://*.vercel.app/**   (if you use preview deployments)

# For server-side operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# POST /api/admin/force-reset-password — use a long random value (e.g. openssl rand -hex 32).
# Vercel: add as Sensitive for Production + Preview only. Teams with “sensitive env” enforcement often
# cannot attach sensitive vars to the Development target — use web/.env.local for local dev instead.
# ADMIN_API_SECRET=

# Password reset via POST /api/auth/reset-password (admin.generateLink + Resend; token_hash links, not PKCE)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Monza CRM <onboarding@resend.dev>
# (Use a verified domain sender in production; see https://resend.com/docs)

# Monza AI Assistant — the in-app chat widget (POST /api/chat) streams from Claude.
# Without this key the assistant replies "AI assistant is not configured.
# ANTHROPIC_API_KEY environment variable is missing." (no code change needed —
# the assistant works for every signed-in user the moment this is set).
# Get a key at https://console.anthropic.com → Settings → API keys.
# Vercel: add as Sensitive for Production (and Preview), then redeploy.
# ANTHROPIC_API_KEY=sk-ant-...

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Optional: client-side idle sign-out (minutes). Omit or 0 = disabled; session follows Supabase JWT only.
# NEXT_PUBLIC_IDLE_LOGOUT_MINUTES=15

# Sentry error / crash reporting (free tier). All four optional — leave unset
# locally and the SDK no-ops. See SENTRY_SETUP.md for full instructions.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<orgId>.ingest.sentry.io/<projectId>
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=   # build-time only, used to upload source maps

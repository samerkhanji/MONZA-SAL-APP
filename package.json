{
  "name": "monza-crm",
  "private": true,
  "description": "Root package so CSS bundlers can resolve shared deps when the editor workspace is the repo folder (not web/).",
  "scripts": {
    "bulk-reset-passwords": "node --env-file=web/.env.local scripts/bulk-reset-passwords.mjs",
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix web",
    "lint": "npm run lint --prefix web",
    "test": "npm run test --prefix web"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/speed-insights": "^2.0.0",
    "tw-animate-css": "^1.4.0"
  }
}
